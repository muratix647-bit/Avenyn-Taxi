    const hasVehicles = vehicles.some((v) => String(v.driver || "").trim() === driverNameToDelete)
    if (hasVehicles) {
      return alert("Denna förare är kopplad till en eller flera bilar. Ändra eller ta bort bilarna först.")
    }

    if (!confirm(`Vill du ta bort föraren ${driverNameToDelete}?`)) return
    setDeletingDriverId(id)

    await supabase.from("advances").delete().eq("driver_name", driverNameToDelete)
    await supabase.from("driver_profiles").delete().eq("driver_name", driverNameToDelete)

    const { error } = await supabase.from("drivers").delete().eq("id", id)
    setDeletingDriverId(null)
    if (error) return alert(error.message)

    if (selectedPayrollDriver === driverNameToDelete) setSelectedPayrollDriver("")
    if (advanceDriverName === driverNameToDelete) setAdvanceDriverName("")
    await loadAll()
  }

