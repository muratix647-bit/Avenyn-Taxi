function todayString() {
  return new Date().toISOString().slice(0, 10)
}

function firstDayOfMonth() {
  const d = new Date()
  d.setDate(1)
  return d.toISOString().slice(0, 10)
}

function firstDayOfWeek() {
  const d = new Date()
  const day = d.getDay()
  const diff = day === 0 ? 6 : day - 1
  d.setDate(d.getDate() - diff)
  return d.toISOString().slice(0, 10)
}

function money(value: number) {
  return `${Number(value || 0).toLocaleString("sv-SE")} kr`
}

function csvEscape(value: unknown) {
  const text = String(value ?? "")
  return `"${text.replace(/"/g, '""')}"`
}

function downloadCSV(filename: string, rows: (string | number)[][]) {
  const csv = rows.map((row) => row.map(csvEscape).join(",")).join("\n")
  const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" })
  const url = URL.createObjectURL(blob)
  const link = document.createElement("a")
  link.href = url
  link.download = filename
  document.body.appendChild(link)
  link.click()
  document.body.removeChild(link)
  URL.revokeObjectURL(url)
}

function formatDate(value?: string | null) {
  if (!value) return "-"
  return String(value).slice(0, 10)
}

function percentToMultiplier(percent: number) {
  return Number(percent || 0) / 100
}

function clampSalaryPercent(value: string | number) {
  const n = Number(value)
  if (!Number.isFinite(n)) return DEFAULT_SALARY_PERCENT
  if (n < 0) return 0
  if (n > 100) return 100
  return n
}

function formatCoords(value?: number | null) {
  if (value === null || value === undefined || Number.isNaN(value)) return "-"
  return Number(value).toFixed(6)
}

function formatSpeed(value?: number | null) {
  if (value === null || value === undefined || Number.isNaN(value)) return "-"
  return `${Math.round(Number(value) * 3.6)} km/h`
}

function mapEmbedUrl(lat?: number | null, lng?: number | null) {
  if (lat === null || lat === undefined || lng === null || lng === undefined) return ""
  const delta = 0.01
  const left = Number(lng) - delta
  const right = Number(lng) + delta
  const top = Number(lat) + delta
  const bottom = Number(lat) - delta
  return `https://www.openstreetmap.org/export/embed.html?bbox=${left}%2C${bottom}%2C${right}%2C${top}&layer=mapnik&marker=${lat}%2C${lng}`
}

