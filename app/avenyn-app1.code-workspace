    const newVehicleName = editName.trim()
    const newReg = editReg.trim().toUpperCase()
    const newDriverName = editDriver.trim()

    const { error } = await supabase
      .from("vehicles")
      .update({
        name: newVehicleName,
        reg: newReg,
        status: editStatus,
        driver: newDriverName,
      })
      .eq("id", id)

    setSavingVehicleEdit(false)
    if (error) return alert(error.message)

    if (oldVehicleName && oldVehicleName !== newVehicleName) {
      await supabase.from("trips").update({ vehicle_name: newVehicleName }).eq("vehicle_id", id)
      await supabase
        .from("expenses")
        .update({ vehicle_name: newVehicleName, reg: newReg })
        .eq("vehicle_id", id)
    } else {
      await supabase.from("expenses").update({ reg: newReg }).eq("vehicle_id", id)
    }

    if (oldVehicle?.driver !== newDriverName) {
      await supabase.from("trips").update({ driver_name: newDriverName }).eq("vehicle_id", id)
    }

    cancelEditVehicle()
    await Promise.all([fetchVehicles(), fetchTrips(), fetchExpenses()])
