  function getVehicleIncome(vehicleId: string) {
    const tripIncome = filteredTrips
      .filter((t) => String(t.vehicle_id) === String(vehicleId))
      .reduce((sum, t) => sum + Number(t.amount || 0), 0)

    const vehicleRow = vehicles.find((v) => String(v.id) === String(vehicleId))
    const driverName = String(vehicleRow?.driver || "").trim()

    const haldaIncome = haldaTrips
      .filter((h) => {
        const haldaDriver = String(h.driver_name || "").trim()
        const haldaDate = String(h.created_at || "").slice(0, 10)
        if (!driverName || haldaDriver !== driverName) return false
        if (dateFrom && haldaDate < dateFrom) return false
        if (dateTo && haldaDate > dateTo) return false
        return true
      })
      .reduce((sum, h) => sum + Number(h.amount || 0), 0)

    return tripIncome + haldaIncome
  }

