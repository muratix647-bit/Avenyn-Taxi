  async function saveDriverEdit(id: string) {
    if (!editDriverName.trim()) return alert("Fyll i förarnamn")
    setSavingDriverEdit(true)

    const oldDriver = drivers.find((d) => String(d.id) === String(id))
    const oldName = String(oldDriver?.full_name || "").trim()
    const newName = editDriverName.trim()

    const { error } = await supabase
      .from("drivers")
      .update({ full_name: newName, phone: editDriverPhone.trim() })
      .eq("id", id)

    if (error) {
      setSavingDriverEdit(false)
      return alert(error.message)
    }

    if (oldName && oldName !== newName) {
      await supabase.from("vehicles").update({ driver: newName }).eq("driver", oldName)
      await supabase.from("trips").update({ driver_name: newName }).eq("driver_name", oldName)
      await supabase.from("advances").update({ driver_name: newName }).eq("driver_name", oldName)
      await supabase
        .from("driver_profiles")
        .update({ driver_name: newName, updated_at: new Date().toISOString() })
        .eq("driver_name", oldName)

      if (selectedPayrollDriver === oldName) setSelectedPayrollDriver(newName)
      if (advanceDriverName === oldName) setAdvanceDriverName(newName)
      if (driver === oldName) setDriver(newName)
      if (editDriver === oldName) setEditDriver(newName)
      if (editAdvanceDriverName === oldName) setEditAdvanceDriverName(newName)
    }

    setSavingDriverEdit(false)
    cancelEditDriver()
    await loadAll()
  }

  async function deleteDriver(id: string) {
