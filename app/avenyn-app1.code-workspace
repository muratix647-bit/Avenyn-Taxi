  async function saveVehicleLocation(vehicleId: string, coords: GeolocationCoordinates) {
    const payload = {
      vehicle_id: vehicleId,
      lat: Number(coords.latitude),
      lng: Number(coords.longitude),
      accuracy: coords.accuracy ?? null,
      speed: coords.speed ?? null,
      heading: coords.heading ?? null,
      updated_at: new Date().toISOString(),
    }

    const existing = vehicleLocations.find(
      (item) => String(item.vehicle_id) === String(vehicleId)
    )

    let error: { message: string } | null = null

    if (existing?.id) {
      const res = await supabase.from("vehicle_locations").update(payload).eq("id", existing.id)
      error = res.error
    } else {
      const res = await supabase.from("vehicle_locations").insert([payload])
      error = res.error
    }

    if (!error) await fetchVehicleLocations()
  }

  async function captureVehicleGPS(vehicleId: string) {
    if (!vehicleId) return alert("Välj bil för GPS")
    if (typeof navigator === "undefined" || !navigator.geolocation) {
      return alert("GPS stöds inte i denna enhet/webbläsare")
    }

    setGpsLoading(true)
    setGpsStatusText("Hämtar GPS-position...")

    navigator.geolocation.getCurrentPosition(
      async (position) => {
        await saveVehicleLocation(vehicleId, position.coords)
        setGpsLoading(false)
        setGpsStatusText("Senaste position sparad")
      },
      (error) => {
        setGpsLoading(false)
        setGpsStatusText("")
        alert(error.message || "Kunde inte hämta GPS-position")
      },
      {
        enableHighAccuracy: true,
        timeout: 20000,
        maximumAge: 0,
      }
    )
  }

  function startLiveTracking(vehicleId: string) {
    if (!vehicleId) return alert("Välj bil först")
    if (typeof navigator === "undefined" || !navigator.geolocation) {
      return alert("GPS stöds inte i denna enhet/webbläsare")
    }

    if (watchIdRef.current !== null) {
      navigator.geolocation.clearWatch(watchIdRef.current)
      watchIdRef.current = null
    }

    setTrackingVehicleId(vehicleId)
    setGpsStatusText("Live tracking startad...")

    watchIdRef.current = navigator.geolocation.watchPosition(
      async (position) => {
        await saveVehicleLocation(vehicleId, position.coords)
        setGpsStatusText(`Live tracking aktiv • ${new Date().toLocaleTimeString("sv-SE")}`)
      },
      (error) => {
        setGpsStatusText("")
        setTrackingVehicleId(null)
        alert(error.message || "Live tracking stoppades")
      },
      {
        enableHighAccuracy: true,
        maximumAge: 0,
        timeout: 20000,
      }
    )
  }

  function stopLiveTracking() {
    if (
      watchIdRef.current !== null &&
      typeof navigator !== "undefined" &&
      navigator.geolocation
    ) {
      navigator.geolocation.clearWatch(watchIdRef.current)
      watchIdRef.current = null
    }
    setTrackingVehicleId(null)
    setGpsStatusText("Live tracking stoppad")
  }

